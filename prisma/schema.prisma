// ============================================================
// BLENDIFY — Prisma Schema
// Production-grade PostgreSQL schema for a premium coffee
// e-commerce platform with international commerce support.
//
// Version: 2.0.0
// Database: PostgreSQL 15+
// ORM: Prisma 5+
// Auth: Jose JWT (stateless, httpOnly cookie)
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  WAREHOUSE
  SUPPORT
}

enum RoastLevel {
  LIGHT
  MEDIUM
  MEDIUM_DARK
  DARK
  EXTRA_DARK
}

enum GrindType {
  WHOLE_BEAN
  COARSE
  MEDIUM_COARSE
  MEDIUM
  FINE
  ESPRESSO
}

enum ProductFormat {
  BAG
  BOTTLE
  CAPSULE
  KIT
  BUNDLE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  REFUND_INITIATED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  CANCELLED
}

enum PaymentGateway {
  RAZORPAY
  STRIPE
  COD
  WALLET
  LOYALTY_POINTS
}

enum ShipmentStatus {
  AWAITING_PICKUP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  RETURNED_TO_ORIGIN
}

enum SubscriptionFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoyaltyTransactionType {
  EARNED_PURCHASE
  EARNED_REVIEW
  EARNED_REFERRAL
  EARNED_BIRTHDAY
  EARNED_BONUS
  REDEEMED
  EXPIRED
  ADJUSTED
}

enum InventoryAction {
  STOCK_IN
  STOCK_OUT
  ORDER_DEDUCTION
  ORDER_CANCELLATION_RESTORE
  RETURN_RESTORE
  MANUAL_ADJUSTMENT
  DAMAGE_WRITE_OFF
  INITIAL_STOCK
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum TaxType {
  GST
  VAT
  SALES_TAX
  NONE
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKUP_SCHEDULED
  PICKED_UP
  RECEIVED
  REFUND_INITIATED
  COMPLETED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum ShippingZone {
  DOMESTIC
  ZONE_1
  ZONE_2
  ZONE_3
  RESTRICTED
}

// ─────────────────────────────────────────────────────────────
// USER & AUTHENTICATION
// ─────────────────────────────────────────────────────────────

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  emailVerified    DateTime?
  password         String?     // bcrypt hash — null for OAuth-only accounts
  firstName        String
  lastName         String
  phone            String?
  phoneVerified    Boolean     @default(false)
  avatar           String?
  role             UserRole    @default(CUSTOMER)
  isActive         Boolean     @default(true)
  loyaltyPoints    Int         @default(0)
  loyaltyTier      LoyaltyTier @default(BRONZE)
  referralCode     String      @unique @default(cuid())
  referredById     String?
  lastLoginAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  referredBy          User?                 @relation("Referrals", fields: [referredById], references: [id])
  referrals           User[]                @relation("Referrals")
  addresses           Address[]
  orders              Order[]
  cart                Cart?
  wishlist            Wishlist?
  reviews             Review[]
  subscriptions       UserSubscription[]
  loyaltyTransactions LoyaltyTransaction[]
  newsletter          NewsletterSubscriber?
  savedPaymentMethods SavedPaymentMethod[]
  returnRequests      ReturnRequest[]
  couponUsages        CouponUsage[]

  @@index([email])
  @@index([referralCode])
  @@index([referredById])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// INTERNATIONAL COMMERCE
// ─────────────────────────────────────────────────────────────

model Country {
  id           String  @id @default(cuid())
  name         String
  code         String  @unique // ISO 3166-1 alpha-2 e.g. "IN", "US"
  currencyCode String  // FK to Currency.code
  phonePrefix  String  // e.g. "+91"
  flag         String  // emoji or URL
  shippingZone ShippingZone @default(ZONE_1)
  taxType      TaxType @default(NONE)
  taxRate      Decimal @default(0) @db.Decimal(5, 4)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  currency     Currency      @relation(fields: [currencyCode], references: [code])
  addresses    Address[]
  regionPrices RegionPrice[]
  taxRules     TaxRule[]
  shippingRates ShippingRate[]

  @@index([code])
  @@index([currencyCode])
  @@index([isActive])
  @@map("countries")
}

model Currency {
  id           String   @id @default(cuid())
  code         String   @unique // ISO 4217 e.g. "INR", "USD"
  name         String
  symbol       String
  exchangeRate Decimal  @db.Decimal(12, 6) // Rate relative to USD
  decimalDigits Int     @default(2) // JPY = 0, most others = 2
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  // Relations
  countries   Country[]
  orders      Order[]
  payments    Payment[]

  @@index([code])
  @@index([isActive])
  @@map("currencies")
}

model TaxRule {
  id          String   @id @default(cuid())
  countryId   String
  taxType     TaxType
  rate        Decimal  @db.Decimal(5, 4) // 0.18 = 18%
  name        String   // "GST", "VAT", etc.
  description String?
  appliesTo   String?  // Product category slug or null = all
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@index([countryId])
  @@index([isActive])
  @@map("tax_rules")
}

// ─────────────────────────────────────────────────────────────
// CATEGORIES & COLLECTIONS
// ─────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  image       String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Collection {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String?
  image        String?
  sortOrder    Int      @default(0)
  isFeatured   Boolean  @default(false)
  isActive     Boolean  @default(true)
  metaTitle    String?
  metaDesc     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products ProductCollection[]

  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
  @@map("collections")
}

// Junction table: Product ↔ Collection (many-to-many)
model ProductCollection {
  productId    String
  collectionId String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([productId])
  @@index([collectionId])
  @@map("product_collections")
}

// ─────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────

model Product {
  id               String        @id @default(cuid())
  slug             String        @unique
  name             String
  tagline          String?
  description      String        @db.Text
  longDescription  String?       @db.Text
  categoryId       String?
  origin           String?       // e.g. "Ethiopia"
  region           String?       // e.g. "Yirgacheffe"
  altitude         String?       // e.g. "1,800 – 2,200m"
  process          String?       // e.g. "Natural", "Washed"
  roastLevel       RoastLevel?
  format           ProductFormat @default(BAG)
  status           ProductStatus @default(DRAFT)
  isNew            Boolean       @default(false)
  isBestSeller     Boolean       @default(false)
  isFeatured       Boolean       @default(false)
  isLimited        Boolean       @default(false)
  sortOrder        Int           @default(0)
  basePrice        Decimal       @db.Decimal(10, 2) // USD
  compareAtPrice   Decimal?      @db.Decimal(10, 2)
  subscriptionPrice Decimal?     @db.Decimal(10, 2)
  metaTitle        String?
  metaDesc         String?
  tags             String[]      @default([])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?

  // Relations
  category         Category?            @relation(fields: [categoryId], references: [id])
  collections      ProductCollection[]
  variants         ProductVariant[]
  images           ProductImage[]
  flavorNotes      FlavorNote[]
  brewGuides       BrewGuide[]
  regionPrices     RegionPrice[]
  reviews          Review[]
  wishlistItems    WishlistItem[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  bundleItems      BundleItem[]
  subscriptionItems UserSubscription[]
  inventoryLogs    InventoryLog[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([isNew])
  @@index([isBestSeller])
  @@index([isFeatured])
  @@index([isLimited])
  @@index([roastLevel])
  @@map("products")
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  name        String    // e.g. "250g — Whole Bean"
  sku         String    @unique
  size        String?   // e.g. "250g", "500g", "1kg", "350ml"
  grind       GrindType @default(WHOLE_BEAN)
  price       Decimal   @db.Decimal(10, 2) // USD
  compareAt   Decimal?  @db.Decimal(10, 2)
  stock       Int       @default(0)
  lowStockThreshold Int @default(5)
  weight      Decimal?  @db.Decimal(8, 2) // grams
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  inventoryLogs InventoryLog[]
  bundleItems   BundleItem[]
  subscriptions UserSubscription[]

  @@index([productId])
  @@index([sku])
  @@index([isActive])
  @@index([stock])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isPrimary])
  @@map("product_images")
}

model FlavorNote {
  id        String @id @default(cuid())
  productId String
  label     String // e.g. "Dark Chocolate"
  intensity Int    // 0-100

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("flavor_notes")
}

model BrewGuide {
  id           String   @id @default(cuid())
  productId    String
  method       String   // e.g. "Pour Over", "Espresso"
  ratio        String   // e.g. "1:15"
  temperature  String   // e.g. "93°C"
  brewTime     String   // e.g. "3:00–3:30"
  instructions String[] @default([])
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("brew_guides")
}

// Region-specific pricing (overrides base price)
model RegionPrice {
  id        String   @id @default(cuid())
  productId String
  countryId String
  price     Decimal  @db.Decimal(10, 2) // Price in country's currency
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([productId, countryId])
  @@index([productId])
  @@index([countryId])
  @@map("region_prices")
}

// ─────────────────────────────────────────────────────────────
// BUNDLES
// ─────────────────────────────────────────────────────────────

model Bundle {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String?  @db.Text
  image        String?
  originalPrice Decimal @db.Decimal(10, 2) // USD
  bundlePrice  Decimal  @db.Decimal(10, 2)
  savingsPercent Decimal @db.Decimal(5, 2)
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  startsAt     DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items     BundleItem[]
  cartItems CartItem[]

  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
  @@map("bundles")
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  productId String
  variantId String
  quantity  Int     @default(1)
  sortOrder Int     @default(0)

  bundle  Bundle         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([bundleId])
  @@index([productId])
  @@index([variantId])
  @@map("bundle_items")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────────────────────

model InventoryLog {
  id            String          @id @default(cuid())
  productId     String
  variantId     String
  action        InventoryAction
  quantity      Int             // positive = added, negative = removed
  previousStock Int
  currentStock  Int
  reason        String?
  reference     String?         // orderId, returnId, etc.
  performedById String?         // userId of admin who did manual adjustment
  createdAt     DateTime        @default(now())

  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([variantId])
  @@index([action])
  @@index([createdAt])
  @@index([reference])
  @@map("inventory_logs")
}

// ─────────────────────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────────────────────

model Cart {
  id             String    @id @default(cuid())
  userId         String?   @unique
  sessionId      String?   @unique  // For guest carts
  couponId       String?
  loyaltyUsed    Int       @default(0)
  notes          String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user   User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon?    @relation(fields: [couponId], references: [id])
  items  CartItem[]

  @@index([userId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id                   String                @id @default(cuid())
  cartId               String
  productId            String
  variantId            String
  bundleId             String?
  quantity             Int                   @default(1)
  isSubscription       Boolean               @default(false)
  subscriptionFrequency SubscriptionFrequency?
  addedAt              DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant  @relation(fields: [variantId], references: [id])
  bundle  Bundle?         @relation(fields: [bundleId], references: [id])

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id        String   @id @default(cuid())
  wishlistId String
  productId  String
  variantId  String
  addedAt    DateTime @default(now())

  wishlist Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product        @relation(fields: [productId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([wishlistId, productId, variantId])
  @@index([wishlistId])
  @@index([productId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────────────────────
// ADDRESSES
// ─────────────────────────────────────────────────────────────

model Address {
  id          String      @id @default(cuid())
  userId      String
  type        AddressType @default(HOME)
  firstName   String
  lastName    String
  company     String?
  phone       String
  line1       String
  line2       String?
  city        String
  state       String
  postalCode  String
  countryId   String
  isDefault   Boolean     @default(false)
  label       String?     // User-defined label e.g. "Mom's House"
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  country     Country     @relation(fields: [countryId], references: [id])
  ordersAsShipping Order[] @relation("ShippingAddress")
  ordersAsBilling  Order[] @relation("BillingAddress")

  @@index([userId])
  @@index([countryId])
  @@index([isDefault])
  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  userId            String?
  guestEmail        String?
  guestPhone        String?
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  shippingAddressId String?
  billingAddressId  String?
  couponId          String?
  currencyCode      String        @default("INR")

  // Financials (stored in order's currency)
  subtotal          Decimal       @db.Decimal(10, 2)
  shippingCost      Decimal       @db.Decimal(10, 2) @default(0)
  tax               Decimal       @db.Decimal(10, 2) @default(0)
  discount          Decimal       @db.Decimal(10, 2) @default(0)
  loyaltyDiscount   Decimal       @db.Decimal(10, 2) @default(0)
  total             Decimal       @db.Decimal(10, 2)

  // USD equivalents for reporting
  totalUsd          Decimal?      @db.Decimal(10, 2)
  exchangeRateUsed  Decimal?      @db.Decimal(12, 6)

  loyaltyPointsEarned Int         @default(0)
  loyaltyPointsUsed   Int         @default(0)
  notes               String?
  internalNotes       String?     // Admin-only notes
  ipAddress           String?
  userAgent           String?
  cancelledAt         DateTime?
  cancelReason        String?
  deliveredAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  user            User?           @relation(fields: [userId], references: [id])
  shippingAddress Address?        @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?        @relation("BillingAddress", fields: [billingAddressId], references: [id])
  coupon          Coupon?         @relation(fields: [couponId], references: [id])
  currency        Currency        @relation(fields: [currencyCode], references: [code])
  items           OrderItem[]
  payments        Payment[]
  shipments       Shipment[]
  timeline        OrderTimeline[]
  returnRequests  ReturnRequest[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([guestEmail])
  @@map("orders")
}

model OrderItem {
  id           String         @id @default(cuid())
  orderId      String
  productId    String
  variantId    String
  productName  String         // Snapshot at time of order
  variantName  String
  sku          String
  quantity     Int
  unitPrice    Decimal        @db.Decimal(10, 2)
  totalPrice   Decimal        @db.Decimal(10, 2)
  discount     Decimal        @db.Decimal(10, 2) @default(0)
  imageUrl     String?
  isSubscription Boolean      @default(false)
  subscriptionFrequency SubscriptionFrequency?
  createdAt    DateTime       @default(now())

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderTimeline {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  message   String
  isPublic  Boolean     @default(true)  // false = admin-only
  metadata  Json?       // e.g. tracking info, carrier details
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_timeline")
}

// ─────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────

model Payment {
  id              String         @id @default(cuid())
  orderId         String
  gateway         PaymentGateway
  status          PaymentStatus  @default(PENDING)
  amount          Decimal        @db.Decimal(10, 2)
  currencyCode    String
  gatewayOrderId  String?        // Razorpay/Stripe order ID
  gatewayPaymentId String?       // Razorpay/Stripe payment ID
  gatewaySignature String?       // Webhook signature
  refundId        String?
  refundAmount    Decimal?       @db.Decimal(10, 2)
  failureCode     String?
  failureReason   String?
  metadata        Json?          // Full gateway response
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order    Order    @relation(fields: [orderId], references: [id])
  currency Currency @relation(fields: [currencyCode], references: [code])

  @@index([orderId])
  @@index([gateway])
  @@index([status])
  @@index([gatewayPaymentId])
  @@map("payments")
}

model SavedPaymentMethod {
  id              String         @id @default(cuid())
  userId          String
  gateway         PaymentGateway
  last4           String?        // Last 4 digits of card
  brand           String?        // Visa, Mastercard, etc.
  expiryMonth     Int?
  expiryYear      Int?
  gatewayCustomerId String?      // Stripe customer ID / Razorpay customer ID
  gatewayMethodId String?        // Stripe payment method ID
  isDefault       Boolean        @default(false)
  createdAt       DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_payment_methods")
}

// ─────────────────────────────────────────────────────────────
// SHIPMENTS
// ─────────────────────────────────────────────────────────────

model Shipment {
  id              String         @id @default(cuid())
  orderId         String
  status          ShipmentStatus @default(AWAITING_PICKUP)
  carrier         String?        // e.g. "Delhivery", "FedEx"
  trackingNumber  String?
  trackingUrl     String?
  estimatedDate   DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  weight          Decimal?       @db.Decimal(8, 2) // grams
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([trackingNumber])
  @@index([status])
  @@map("shipments")
}

model ShippingRate {
  id              String       @id @default(cuid())
  countryId       String
  name            String       // e.g. "Standard Shipping"
  description     String?
  minOrderAmount  Decimal?     @db.Decimal(10, 2) // Free if above this
  freeThreshold   Decimal?     @db.Decimal(10, 2)
  price           Decimal      @db.Decimal(10, 2)
  estimatedDays   String       // e.g. "3-5 business days"
  isActive        Boolean      @default(true)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@index([countryId])
  @@index([isActive])
  @@map("shipping_rates")
}

// ─────────────────────────────────────────────────────────────
// RETURNS & REFUNDS
// ─────────────────────────────────────────────────────────────

model ReturnRequest {
  id           String       @id @default(cuid())
  orderId      String
  userId       String
  status       ReturnStatus @default(REQUESTED)
  reason       String
  description  String?
  images       String[]     @default([])
  refundAmount Decimal?     @db.Decimal(10, 2)
  adminNote    String?
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("return_requests")
}

// ─────────────────────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────────────────────

model Review {
  id         String       @id @default(cuid())
  productId  String
  userId     String?
  authorName String
  rating     Int          // 1-5
  title      String?
  body       String       @db.Text
  status     ReviewStatus @default(PENDING)
  verified   Boolean      @default(false) // Purchased the product
  helpful    Int          @default(0)
  images     String[]     @default([])
  reply      String?      // Admin reply
  repliedAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────
// COUPONS
// ─────────────────────────────────────────────────────────────

model Coupon {
  id               String     @id @default(cuid())
  code             String     @unique
  type             CouponType
  value            Decimal    @db.Decimal(10, 2) // percent or fixed amount
  description      String?
  minOrderAmount   Decimal?   @db.Decimal(10, 2)
  maxDiscountAmount Decimal?  @db.Decimal(10, 2) // cap for percentage coupons
  maxUses          Int?
  usedCount        Int        @default(0)
  maxUsesPerUser   Int        @default(1)
  isActive         Boolean    @default(true)
  startsAt         DateTime?
  expiresAt        DateTime?
  applicableToAll  Boolean    @default(true)
  applicableProducts String[] @default([]) // productIds
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  usages CouponUsage[]
  orders Order[]
  carts  Cart[]

  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String?
  usedAt    DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([couponId])
  @@index([userId])
  @@map("coupon_usages")
}

// ─────────────────────────────────────────────────────────────
// SUBSCRIPTIONS (Product Subscriptions)
// ─────────────────────────────────────────────────────────────

model SubscriptionPlan {
  id          String                @id @default(cuid())
  name        String                // "Monthly", "Quarterly"
  frequency   SubscriptionFrequency
  discount    Decimal               @db.Decimal(5, 2) // percentage
  description String?
  perks       String[]              @default([])
  isActive    Boolean               @default(true)
  sortOrder   Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id                String               @id @default(cuid())
  userId            String
  productId         String
  variantId         String
  planId            String
  status            SubscriptionStatus   @default(ACTIVE)
  quantity          Int                  @default(1)
  price             Decimal              @db.Decimal(10, 2)
  discount          Decimal              @db.Decimal(5, 2)
  nextBillingDate   DateTime
  lastBilledDate    DateTime?
  pausedAt          DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  shippingAddressId String?
  totalOrders       Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user    User              @relation(fields: [userId], references: [id])
  product Product           @relation(fields: [productId], references: [id])
  variant ProductVariant    @relation(fields: [variantId], references: [id])
  plan    SubscriptionPlan  @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("user_subscriptions")
}

// ─────────────────────────────────────────────────────────────
// LOYALTY & REFERRALS
// ─────────────────────────────────────────────────────────────

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  userId      String
  type        LoyaltyTransactionType
  points      Int                    // positive = earned, negative = redeemed
  balance     Int                    // points balance after this transaction
  description String
  orderId     String?
  expiresAt   DateTime?
  createdAt   DateTime               @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([orderId])
  @@index([expiresAt])
  @@map("loyalty_transactions")
}

// ─────────────────────────────────────────────────────────────
// NEWSLETTER
// ─────────────────────────────────────────────────────────────

model NewsletterSubscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  userId      String?   @unique
  firstName   String?
  source      String    @default("website") // "website", "checkout", "popup"
  tags        String[]  @default([])
  isActive    Boolean   @default(true)
  confirmedAt DateTime?
  unsubscribedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([isActive])
  @@index([source])
  @@map("newsletter_subscribers")
}

// ─────────────────────────────────────────────────────────────
// ANALYTICS EVENTS (lightweight event store)
// ─────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(cuid())
  event      String   // "product_view", "add_to_cart", "purchase" etc.
  userId     String?
  sessionId  String?
  productId  String?
  metadata   Json?    // Event-specific data
  country    String?  // ISO code
  currency   String?  // ISO code
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([productId])
  @@index([createdAt])
  @@index([country])
  @@map("analytics_events")
}
