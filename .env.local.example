# ==============================================================
# BLENDIFY — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ==============================================================

# ── Authentication (JWT) ───────────────────────────────────────
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_32

# ── Database (PostgreSQL via Prisma) ──────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Leave as-is to run in demo mode (no DB required locally)
DATABASE_URL=REPLACE_WITH_postgresql_connection_string

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (optional — for contact form) ───────────────────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=REPLACE_WITH_your_resend_api_key
# EMAIL_FROM=no-reply@blendify.coffee
